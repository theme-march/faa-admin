<!-- Page header -->
<div class="page-header page-header-light">
    <div class="breadcrumb-line breadcrumb-line-light header-elements-md-inline">
        <div class="d-flex">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-item"><i class="icon-home2 mr-2"></i> Home</a>
                <span class="breadcrumb-item active">Payment Setup</span>
            </div>
            <a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
        </div>
    </div>
</div>

<style>
    .payment-setup-page .card {
        border-radius: 14px;
        border: 1px solid #dbe4f0;
    }

    .payment-setup-page .page-subtitle {
        margin-top: 4px;
        margin-bottom: 0;
        color: #64748b;
        font-size: 13px;
    }

    .payment-setup-page .quick-guide {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
    }

    .payment-setup-page .quick-guide-item {
        border: 1px solid #dbe4f0;
        border-radius: 10px;
        padding: 10px 12px;
        background: #f8fbff;
        font-size: 12px;
        line-height: 1.5;
        color: #334155;
    }

    .payment-setup-page .quick-guide-item b {
        display: block;
        color: #1e293b;
        margin-bottom: 2px;
    }

    .payment-setup-page .helper-box {
        border: 1px solid #dbe4f0;
        border-radius: 10px;
        padding: 14px;
        background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
        margin-bottom: 16px;
    }

    .payment-setup-page .helper-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

    .payment-setup-page .helper-chip {
        border: 1px solid #c7d2fe;
        background: #eef2ff;
        color: #3730a3;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
    }

    @media (max-width: 1199px) {
        .payment-setup-page .quick-guide {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="content payment-setup-page">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header header-elements-inline">
                    <div>
                        <h5 class="card-title mb-0">Payment Setup</h5>
                        <p class="page-subtitle">Set frontend redirect URL, SSL gateway mode, and cash/SSL availability from one clear screen.</p>
                    </div>
                </div>

                <% if (messages.error) { %>
                    <div style="margin: 0 20px 0 20px" class="alert alert-danger alert-styled-left alert-dismissible">
                        <span class="font-weight-semibold">Error!</span> <%- messages.error %>
                    </div>
                <% } %>

                <% if (messages.success) { %>
                    <div style="margin: 0 20px 0 20px" class="alert alert-success alert-styled-left alert-arrow-left alert-dismissible">
                        <span class="font-weight-semibold">Success!</span> <%- messages.success %>
                    </div>
                <% } %>

                <div class="card-body">
                    <form action="/payment-settings" method="post" name="form1">
                        <input type="hidden" name="id" value="<%= id %>" />

                        <div class="quick-guide">
                            <div class="quick-guide-item">
                                <b>Step 1: System Status</b>
                                Keep Active to allow payment processing on the public website.
                            </div>
                            <div class="quick-guide-item">
                                <b>Step 2: Site URL</b>
                                Use your frontend website URL here, not the admin/CMS URL.
                            </div>
                            <div class="quick-guide-item">
                                <b>Step 3: Gateway Mode</b>
                                Use Sandbox for testing and Live for production SSLCommerz.
                            </div>
                        </div>

                        <div class="helper-box">
                            <div class="font-weight-semibold mb-2">Admin tip</div>
                            <div class="text-muted">
                                Live public website: <code>https://faa-dubd.org</code><br>
                                Admin/CMS website: <code>https://cms.faa-dubd.org</code><br>
                                Put only the <b>public frontend URL</b> into the <b>Site URL</b> field.
                            </div>
                            <div class="helper-actions">
                                <button type="button" class="helper-chip js-fill-site-url" data-url="https://faa-dubd.org">Use Live Frontend URL</button>
                                <button type="button" class="helper-chip js-fill-site-url" data-url="http://localhost:3001">Use Local Frontend URL</button>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>System Status</label>
                                    <select name="status" class="form-control select-fixed-single" data-fouc>
                                        <% if (String(status) === '1'){%>
                                            <option value="1" selected>Active</option>
                                            <option value="0">Inactive</option>
                                        <%}else{%>
                                            <option value="1">Active</option>
                                            <option value="0" selected>Inactive</option>
                                        <%}%>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>SSL Payment</label>
                                    <select name="ssl_enabled" class="form-control select-fixed-single" data-fouc>
                                        <% if (String(ssl_enabled) === '1'){%>
                                            <option value="1" selected>On</option>
                                            <option value="0">Off</option>
                                        <%}else{%>
                                            <option value="1">On</option>
                                            <option value="0" selected>Off</option>
                                        <%}%>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>Cash Payment</label>
                                    <select name="cash_enabled" class="form-control select-fixed-single" data-fouc>
                                        <% if (String(cash_enabled) === '1'){%>
                                            <option value="1" selected>On</option>
                                            <option value="0">Off</option>
                                        <%}else{%>
                                            <option value="1">On</option>
                                            <option value="0" selected>Off</option>
                                        <%}%>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Store ID</label>
                                    <input type="text" name="store_id" value="<%= store_id %>" class="form-control" placeholder="SSLCommerz Store ID">
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Store Password</label>
                                    <input type="text" name="store_passwd" value="<%= store_passwd %>" class="form-control" placeholder="SSLCommerz Store Password">
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Cash Payment Notice</label>
                            <textarea
                                name="cash_payment_notice"
                                class="form-control"
                                rows="3"
                                placeholder="Example: bKash/Nagad number: 017xxxxxxxx (Send Money option)"
                            ><%= cash_payment_notice || '' %></textarea>
                            <span class="form-text text-muted">This notice will be shown on frontend when user selects Cash payment.</span>
                        </div>

                        <div class="form-group">
                            <label>Site URL</label>
                            <input type="text" id="payment-site-url" name="site_url" value="<%= site_url %>" class="form-control" placeholder="https://faa-dubd.org" required>
                            <span class="form-text text-muted">This must be the frontend/public website URL. Payment success, fail and cancel pages redirect here.</span>
                        </div>

                        <div class="form-group">
                            <label>Gateway Mode</label>
                            <select name="is_live" class="form-control select-fixed-single" data-fouc>
                                <% if (String(is_live) === '1'){%>
                                    <option value="1" selected>Live</option>
                                    <option value="0">Sandbox</option>
                                <%}else{%>
                                    <option value="1">Live</option>
                                    <option value="0" selected>Sandbox</option>
                                <%}%>
                            </select>
                        </div>

                        <div class="text-right">
                            <button type="submit" class="btn btn-primary">Update
                                <i class="icon-paperplane ml-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var siteUrlInput = document.getElementById("payment-site-url");
        document.querySelectorAll(".js-fill-site-url").forEach(function (button) {
            button.addEventListener("click", function () {
                if (siteUrlInput) {
                    siteUrlInput.value = button.getAttribute("data-url") || "";
                    siteUrlInput.focus();
                }
            });
        });
    });
</script>
