<!-- Page header -->
<div class="page-header page-header-light">
    <div class="breadcrumb-line breadcrumb-line-light header-elements-md-inline">
        <div class="d-flex">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-item"><i class="icon-home2 mr-2"></i> Home</a>
                <span class="breadcrumb-item active">YouTube Video</span>
            </div>
            <a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
        </div>
    </div>
</div>

<div class="content">
    <div class="card">
        <div class="card-header header-elements-inline">
            <h5 class="card-title">YouTube Video List</h5>
        </div>

        <div class="card-body">
            <button onclick="location.href='/youtube_video/add'" type="button" class="btn btn-primary">
                <i class="icon-plus2 mr-2"></i>
                Add
            </button>
        </div>

        <table id="list" class="table datatable-basic table-bordered table-striped table-hover">
            <thead>
            <tr>
                <th>Title</th>
                <th>YouTube URL</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<script>
    $(document).ready(function() {
        function dataLoad() {
            $('#list').DataTable({
                "processing": true,
                "serverSide": true,
                "ordering": false,
                "search": true,
                "destroy": true,
                "pageLength": 50,
                "searching": true,
                "ajax": {
                    "url": "/youtube_video/data_list",
                    "type": "POST",
                    "datatype": "json",
                },
                "createdRow": function(row, data) {
                    if (data.status === 1) {
                        $('td:eq(2)', row).html('<span class="badge badge-success">Published</span>');
                    } else {
                        $('td:eq(2)', row).html('<span class="badge badge-secondary">Unpublished</span>');
                    }
                },
                "columns": [
                    { "data": "title" },
                    { "data": "youtube_url" },
                    { "data": "status" },
                    { "data": "action" },
                ]
            });
        }

        dataLoad();

        $("#list").on('click', '#delete', function () {
            var delid = $(this).attr('data-delete-id');
            bootbox.confirm({
                title: 'Delete',
                message: 'Do you want to delete?',
                buttons: {
                    confirm: {
                        label: 'Yes',
                        className: 'btn-primary'
                    },
                    cancel: {
                        label: 'No',
                        className: 'btn-link'
                    }
                },
                callback: function (result) {
                    if (result) {
                        $.ajax({
                            type: "post",
                            url: "/youtube_video/del",
                            data: { del_id: delid },
                            datatype: "json",
                            traditional: true,
                            success: function (data) {
                                if (data.success) {
                                    window.location.href = "/youtube_video";
                                } else {
                                    bootbox.alert({
                                        title: 'Delete Failed!',
                                        message: data.message
                                    });
                                }
                            }
                        });
                    }
                }
            });
        });
    });
</script>
