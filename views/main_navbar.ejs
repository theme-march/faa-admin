<script>
    $(document).ready(function () {
        $('#admin-top-search-input').on('keydown', function (e) {
            if (e.key !== 'Enter') return;
            e.preventDefault();
            var query = ($(this).val() || '').toLowerCase().trim();
            if (!query) return;

            var $match = $('.nav.nav-sidebar > li > a.nav-link').filter(function () {
                return ($(this).text() || '').toLowerCase().indexOf(query) !== -1;
            }).first();

            if ($match.length && $match.attr('href')) {
                window.location.href = $match.attr('href');
            }
        });
    });
</script>
