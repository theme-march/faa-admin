<div class="page-header page-header-light">
    <div class="breadcrumb-line breadcrumb-line-light header-elements-md-inline">
        <div class="d-flex">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-item"><i class="icon-home2 mr-2"></i> Home</a>
                <span class="breadcrumb-item active">Membership Invoice Setup</span>
            </div>
            <a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
        </div>
    </div>
</div>

<style>
    .membership-invoice-settings-page .card {
        border-radius: 14px;
        border: 1px solid #dbe4f0;
    }

    .membership-invoice-settings-page .card-title {
        font-weight: 700;
    }

    .membership-invoice-settings-page .invoice-subtitle {
        margin-top: 4px;
        margin-bottom: 0;
        color: #64748b;
        font-size: 13px;
    }

    .membership-invoice-settings-page .quick-steps {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
    }

    .membership-invoice-settings-page .quick-step-item {
        border: 1px solid #dbe4f0;
        border-radius: 10px;
        padding: 10px 12px;
        background: #f8fbff;
        font-size: 12px;
        line-height: 1.5;
        color: #334155;
    }

    .membership-invoice-settings-page .quick-step-item b {
        display: block;
        color: #1e293b;
        margin-bottom: 2px;
    }

    .membership-invoice-settings-page .invoice-setting-block {
        border: 1px solid #dbe4f0;
        border-radius: 10px;
        padding: 14px;
        margin-bottom: 14px;
        background: #ffffff;
    }

    .membership-invoice-settings-page .invoice-setting-block h6 {
        margin-bottom: 12px;
        font-size: 14px;
    }

    .membership-invoice-settings-page .action-bar {
        position: sticky;
        bottom: 8px;
        z-index: 20;
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding: 10px;
        border: 1px solid #dbe4f0;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(4px);
    }

    .membership-invoice-settings-page .preview-frame {
        width: 100%;
        min-height: 860px;
        border: 1px solid #d9e1ec;
        border-radius: 10px;
        background: #fff;
    }

    .membership-invoice-settings-page .helper-box {
        border: 1px solid #dbe4f0;
        border-radius: 10px;
        padding: 12px 14px;
        background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
        margin-bottom: 14px;
    }

    .membership-invoice-settings-page .helper-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

    .membership-invoice-settings-page .helper-chip {
        border: 1px solid #c7d2fe;
        background: #eef2ff;
        color: #3730a3;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
    }

    @media (max-width: 1199px) {
        .membership-invoice-settings-page .quick-steps {
            grid-template-columns: 1fr;
        }

        .membership-invoice-settings-page .action-bar {
            flex-direction: column;
        }

        .membership-invoice-settings-page .action-bar .btn {
            width: 100%;
        }
    }
</style>

<div class="content membership-invoice-settings-page">
    <div class="row">
        <div class="col-lg-7 col-xl-7">
            <div class="card">
                <div class="card-header header-elements-inline">
                    <div>
                        <h5 class="card-title mb-0">Membership Invoice Setup</h5>
                        <p class="invoice-subtitle">Control membership invoice title, subtitle, contact line and logo from one clean screen.</p>
                    </div>
                </div>

                <% if (messages.error) { %>
                    <div style="margin: 0 20px 0 20px" class="alert alert-danger alert-styled-left alert-dismissible">
                        <span class="font-weight-semibold">Error!</span> <%- messages.error %>
                    </div>
                <% } %>

                <% if (messages.success) { %>
                    <div style="margin: 0 20px 0 20px" class="alert alert-success alert-styled-left alert-arrow-left alert-dismissible">
                        <span class="font-weight-semibold">Success!</span> <%- messages.success %>
                    </div>
                <% } %>

                <div class="card-body">
                    <div class="quick-steps">
                        <div class="quick-step-item">
                            <b>Step 1: Enable Setup</b>
                            Keep the invoice setup active so membership invoice download uses these settings.
                        </div>
                        <div class="quick-step-item">
                            <b>Step 2: Customize Branding</b>
                            Update title, subtitle, contact line and logo without touching code.
                        </div>
                        <div class="quick-step-item">
                            <b>Step 3: Check Preview</b>
                            Review the live PDF-style preview before saving final changes.
                        </div>
                    </div>

                    <form action="/membership-invoice-settings" method="post" enctype="multipart/form-data" class="membership-invoice-settings-form">
                        <input type="hidden" name="id" value="<%= id %>">

                        <div class="helper-box">
                            <div class="font-weight-semibold mb-2">Easy setup guide</div>
                            <div class="text-muted">
                                <b>Site URL</b> should be the public frontend URL, for example <code>https://faa-dubd.org</code>.<br>
                                For PrivateEmail or similar SMTP, common values are:
                                <code>mail.privateemail.com</code>, port <code>465</code>, secure <code>Yes</code>.
                            </div>
                            <div class="helper-actions">
                                <button type="button" class="helper-chip js-membership-site-url" data-url="https://faa-dubd.org">Use Live Frontend URL</button>
                                <button type="button" class="helper-chip js-membership-site-url" data-url="http://localhost:3001">Use Local Frontend URL</button>
                                <button type="button" class="helper-chip js-membership-smtp-fill" data-host="mail.privateemail.com" data-port="465" data-secure="1">Use Common SMTP</button>
                            </div>
                        </div>

                        <div class="invoice-setting-block">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Setup Status:</label>
                                        <select name="status" class="form-control select-fixed-single" data-fouc>
                                            <% if (String(status) === "1") { %>
                                                <option value="1" selected>Active</option>
                                                <option value="0">Inactive</option>
                                            <% } else { %>
                                                <option value="1">Active</option>
                                                <option value="0" selected>Inactive</option>
                                            <% } %>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Auto Send After Payment:</label>
                                        <select name="auto_send_status" class="form-control select-fixed-single" data-fouc>
                                            <% if (String(auto_send_status) === "1") { %>
                                                <option value="1" selected>On</option>
                                                <option value="0">Off</option>
                                            <% } else { %>
                                                <option value="1">On</option>
                                                <option value="0" selected>Off</option>
                                            <% } %>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Site URL:</label>
                                        <input type="text" id="membership-site-url" name="site_url" value="<%= site_url %>" class="form-control" placeholder="https://faa-dubd.org">
                                        <span class="form-text text-muted">Use the public frontend URL here. Do not use the admin/CMS URL.</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="invoice-setting-block">
                            <h6 class="font-weight-semibold">SMTP</h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>SMTP Host:</label>
                                        <input type="text" id="membership-smtp-host" name="smtp_host" value="<%= smtp_host %>" class="form-control" placeholder="mail.privateemail.com" required>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>SMTP Port:</label>
                                        <input type="number" id="membership-smtp-port" name="smtp_port" value="<%= smtp_port %>" class="form-control" placeholder="465" required>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>Secure:</label>
                                        <select id="membership-smtp-secure" name="smtp_secure" class="form-control select-fixed-single" data-fouc>
                                            <% if (String(smtp_secure) === "1") { %>
                                                <option value="1" selected>Yes</option>
                                                <option value="0">No</option>
                                            <% } else { %>
                                                <option value="1">Yes</option>
                                                <option value="0" selected>No</option>
                                            <% } %>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>SMTP User:</label>
                                        <input type="text" name="smtp_user" value="<%= smtp_user %>" class="form-control" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>SMTP Password:</label>
                                        <input type="password" name="smtp_pass" value="<%= smtp_pass %>" class="form-control" autocomplete="new-password" required>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="invoice-setting-block">
                            <h6 class="font-weight-semibold">Email Sender</h6>
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>From Name:</label>
                                        <input type="text" name="from_name" value="<%= from_name %>" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>From Email:</label>
                                        <input type="email" name="from_email" value="<%= from_email %>" class="form-control" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Reply-To Email:</label>
                                        <input type="email" name="reply_to_email" value="<%= reply_to_email %>" class="form-control">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="invoice-setting-block">
                            <h6 class="font-weight-semibold">Invoice Content</h6>
                            <div class="form-group">
                                <label>Email Subject:</label>
                                <input type="text" name="email_subject" value="<%= email_subject %>" class="form-control" required>
                            </div>

                            <div class="form-group">
                                <label>Email Body:</label>
                                <textarea name="email_body" rows="6" class="form-control" required><%= email_body %></textarea>
                                <span class="form-text text-muted">Available placeholders: <code>{{full_name}}</code>, <code>{{membership_number}}</code>, <code>{{member_type}}</code>, <code>{{organization_name}}</code>, <code>{{pay_amount}}</code>, <code>{{tx_tran_id}}</code>, <code>{{payment_date}}</code></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Invoice Title:</label>
                                        <input type="text" name="invoice_title" id="invoice_title" value="<%= invoice_title %>" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Invoice Subtitle:</label>
                                        <input type="text" name="invoice_subtitle" id="invoice_subtitle" value="<%= invoice_subtitle %>" class="form-control">
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label>Contact Details Line:</label>
                                <input type="text" name="contact_details" id="contact_details" value="<%= contact_details %>" class="form-control">
                            </div>
                        </div>

                        <div class="invoice-setting-block">
                            <h6 class="font-weight-semibold">Logo</h6>
                            <div class="form-group">
                                <label>Upload Membership Invoice Logo (optional):</label>
                                <input type="hidden" name="logo_path" id="logo_path" value="<%= logo_path %>">
                                <input type="file" name="membershipInvoiceLogoFile" id="membershipInvoiceLogoFile" class="form-control" accept="image/*">
                                <span class="form-text text-muted">Default logo: <code><%= default_logo_path %></code>. If no file is uploaded, current/default logo will remain.</span>
                            </div>

                            <div class="mt-2">
                                <img id="membership_invoice_logo_preview" src="<%= logo_preview_url || '' %>" alt="Membership Invoice Logo Preview" style="<%= logo_preview_url ? '' : 'display:none;' %>max-width: 260px; max-height: 90px; object-fit: contain; border: 1px solid #e5e7eb; border-radius: 8px; padding: 6px; background: #fff;">
                            </div>

                            <input type="text" value="<%= logo_path %>" class="form-control mt-3" readonly>
                        </div>

                        <div class="alert alert-info border-0">
                            Paid membership payment complete hole event invoice-er moto auto email invoice pathano jabe. Ei setup thekei PDF design, sender info, ar auto-send behavior manage hobe.
                        </div>

                        <div class="action-bar">
                            <button type="submit" class="btn btn-primary">Update Membership Invoice Settings
                                <i class="icon-paperplane ml-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5 col-xl-5">
            <div class="card" style="position: sticky; top: 84px;">
                <div class="card-header">
                    <h6 class="card-title mb-0">Membership Invoice Live Preview</h6>
                </div>
                <div class="card-body">
                    <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:8px;">
                        <span class="badge badge-primary" style="font-size:11px;">Live Preview</span>
                        <span id="membership_invoice_change_state" class="text-muted" style="font-size:11px;">No unsaved changes</span>
                    </div>
                    <iframe id="membership_invoice_preview_frame" class="preview-frame" title="Membership Invoice Preview"></iframe>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var siteUrlInput = document.getElementById("membership-site-url");
        var smtpHost = document.getElementById("membership-smtp-host");
        var smtpPort = document.getElementById("membership-smtp-port");
        var smtpSecure = document.getElementById("membership-smtp-secure");

        document.querySelectorAll(".js-membership-site-url").forEach(function (button) {
            button.addEventListener("click", function () {
                if (siteUrlInput) {
                    siteUrlInput.value = button.getAttribute("data-url") || "";
                    siteUrlInput.focus();
                }
            });
        });

        document.querySelectorAll(".js-membership-smtp-fill").forEach(function (button) {
            button.addEventListener("click", function () {
                if (smtpHost) smtpHost.value = button.getAttribute("data-host") || "";
                if (smtpPort) smtpPort.value = button.getAttribute("data-port") || "";
                if (smtpSecure) smtpSecure.value = button.getAttribute("data-secure") || "1";
                if (window.jQuery && window.jQuery.fn.select2) {
                    window.jQuery(smtpSecure).trigger("change");
                }
            });
        });
    });
</script>

<script>
    (function () {
        const previewFrame = document.getElementById("membership_invoice_preview_frame");
        const changeState = document.getElementById("membership_invoice_change_state");
        const titleInput = document.getElementById("invoice_title");
        const subtitleInput = document.getElementById("invoice_subtitle");
        const contactInput = document.getElementById("contact_details");
        const logoPathInput = document.getElementById("logo_path");
        const logoFileInput = document.getElementById("membershipInvoiceLogoFile");
        const logoPreview = document.getElementById("membership_invoice_logo_preview");

        const initialState = {
            title: String(titleInput?.value || ""),
            subtitle: String(subtitleInput?.value || ""),
            contact: String(contactInput?.value || ""),
            logoUrl: "<%- logo_preview_url || '' %>"
        };

        const escapeHtml = (value) => String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");

        const formatPreviewAmount = (value) => {
            const numeric = Number(String(value || "").replace(/,/g, ""));
            return new Intl.NumberFormat("en-US", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(Number.isFinite(numeric) ? numeric : 0);
        };

        const resolveCurrentLogoUrl = () => {
            if (logoFileInput?.files?.[0]) {
                return URL.createObjectURL(logoFileInput.files[0]);
            }

            const rawPath = String(logoPathInput?.value || "").trim();
            if (!rawPath) return initialState.logoUrl || "/global_assets/images/banner-logo.jpg";
            if (rawPath.startsWith("http://") || rawPath.startsWith("https://")) return rawPath;

            const withSlash = rawPath.startsWith("/") ? rawPath : `/${rawPath}`;
            return withSlash.replace(/^\/public\//, "/");
        };

        const isDirty = () => {
            return (
                String(titleInput?.value || "") !== initialState.title ||
                String(subtitleInput?.value || "") !== initialState.subtitle ||
                String(contactInput?.value || "") !== initialState.contact ||
                Boolean(logoFileInput?.files?.[0])
            );
        };

        const buildPreviewHtml = () => {
            const title = escapeHtml(titleInput?.value || "Membership Payment Invoice");
            const subtitle = escapeHtml(subtitleInput?.value || "Official payment receipt");
            const contact = escapeHtml(contactInput?.value || "-");
            const logo = resolveCurrentLogoUrl();
            const totalPaid = formatPreviewAmount(10000);

            if (logoPreview) {
                if (logo) {
                    logoPreview.src = logo;
                    logoPreview.style.display = "block";
                } else {
                    logoPreview.style.display = "none";
                }
            }

            return `
                <!DOCTYPE html>
                <html lang="en">
                  <head>
                    <meta charset="UTF-8" />
                    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
                    <style>
                      body { font-family: Arial, sans-serif; color: #1f2937; margin: 0; padding: 18px; background: #ffffff; }
                      .invoice-shell { max-width: 820px; margin: 0 auto; border: 1px solid #e5e7eb; border-radius: 18px; padding: 24px; box-sizing: border-box; }
                      .invoice-header { display: flex; align-items: center; justify-content: space-between; gap: 18px; border-bottom: 2px solid #ede9fe; padding-bottom: 16px; margin-bottom: 20px; }
                      .invoice-logo { flex: 1; }
                      .invoice-logo img { max-width: 220px; width: 100%; height: auto; display: block; }
                      .invoice-title { flex: 1; text-align: right; }
                      .invoice-title h1 { margin: 0; font-size: 23px; color: #4c1d95; }
                      .invoice-title p { margin: 6px 0 0; color: #64748b; font-size: 12px; }
                      .invoice-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 18px; }
                      .invoice-card { border: 1px solid #e5e7eb; border-radius: 14px; padding: 14px; background: #fafaff; }
                      .invoice-card h3 { margin: 0 0 10px; font-size: 15px; color: #111827; }
                      .invoice-row { display: flex; justify-content: space-between; gap: 10px; padding: 5px 0; border-bottom: 1px solid #eef2ff; font-size: 11px; }
                      .invoice-row:last-child { border-bottom: 0; }
                      .invoice-row span:first-child { color: #64748b; }
                      .amount-box { margin-top: 8px; padding-top: 10px; border-top: 2px solid #ddd6fe; }
                      .amount-box .invoice-row strong { font-size: 15px; color: #4c1d95; }
                      .invoice-contact { margin-top: 6px; border-top: 1px dashed #cbd5e1; padding-top: 12px; color: #334155; font-size: 12px; }
                    </style>
                  </head>
                  <body>
                    <div class="invoice-shell">
                      <div class="invoice-header">
                        <div class="invoice-logo">${logo ? `<img src="${logo}" alt="FAA" />` : ""}</div>
                        <div class="invoice-title">
                          <h1>${title}</h1>
                          <p>${subtitle}</p>
                          <p>Payment record #Preview</p>
                        </div>
                      </div>
                      <div class="invoice-grid">
                        <div class="invoice-card">
                          <h3>Member Details</h3>
                          <div class="invoice-row"><span>Name</span><strong>Sample Member</strong></div>
                          <div class="invoice-row"><span>Membership Number</span><strong>LM0001</strong></div>
                          <div class="invoice-row"><span>Membership Type</span><strong>Lifetime Member</strong></div>
                          <div class="invoice-row"><span>Organization</span><strong>Sample Organization</strong></div>
                          <div class="invoice-row"><span>Email</span><strong>member@example.com</strong></div>
                          <div class="invoice-row"><span>Phone</span><strong>01700000000</strong></div>
                        </div>
                        <div class="invoice-card">
                          <h3>Payment Details</h3>
                          <div class="invoice-row"><span>Transaction ID</span><strong>Preview TXN</strong></div>
                          <div class="invoice-row"><span>Payment Date</span><strong>Jul 02, 2026 10:00 AM</strong></div>
                          <div class="invoice-row"><span>Payment Method</span><strong>ssl</strong></div>
                          <div class="invoice-row"><span>Card/Account</span><strong>-</strong></div>
                          <div class="invoice-row"><span>Status</span><strong>VALID</strong></div>
                          <div class="amount-box">
                            <div class="invoice-row"><span>Total Paid</span><strong>BDT ${totalPaid}</strong></div>
                          </div>
                        </div>
                      </div>
                      <div class="invoice-contact">
                        <strong>Contact details:</strong> ${contact}
                      </div>
                    </div>
                  </body>
                </html>
            `;
        };

        const renderPreview = () => {
            previewFrame.srcdoc = buildPreviewHtml();

            if (isDirty()) {
                changeState.textContent = "Unsaved changes in preview";
                changeState.style.color = "#f59e0b";
            } else {
                changeState.textContent = "No unsaved changes";
                changeState.style.color = "#6b7280";
            }
        };

        [titleInput, subtitleInput, contactInput, logoFileInput].forEach(function (element) {
            if (!element) return;
            element.addEventListener("input", renderPreview);
            element.addEventListener("change", renderPreview);
        });

        renderPreview();
    })();
</script>
