<!-- Page header -->
<div class="page-header page-header-light">
    <div class="breadcrumb-line breadcrumb-line-light header-elements-md-inline">
        <div class="d-flex">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-item"><i class="icon-home2 mr-2"></i> Home</a>
                <span class="breadcrumb-item active">Forgot Password SMTP</span>
            </div>
            <a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
        </div>
    </div>
</div>

<style>
    .forgot-password-smtp-page .card {
        border-radius: 14px;
        border: 1px solid #dbe4f0;
    }

    .forgot-password-smtp-page .page-subtitle {
        margin-top: 4px;
        margin-bottom: 0;
        color: #64748b;
        font-size: 13px;
    }

    .forgot-password-smtp-page .helper-box {
        border: 1px solid #dbe4f0;
        border-radius: 10px;
        padding: 12px 14px;
        background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
        margin-bottom: 16px;
    }

    .forgot-password-smtp-page .helper-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

    .forgot-password-smtp-page .helper-chip {
        border: 1px solid #c7d2fe;
        background: #eef2ff;
        color: #3730a3;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
    }
</style>

<div class="content forgot-password-smtp-page">
    <div class="row">
        <div class="col-md-9">
            <div class="card">
                <div class="card-header header-elements-inline">
                    <div>
                        <h5 class="card-title mb-0">Forgot Password SMTP Settings</h5>
                        <p class="page-subtitle">Configure the email server used only for member password reset emails.</p>
                    </div>
                </div>

                <% if (messages.error) { %>
                    <div style="margin: 0 20px 0 20px" class="alert alert-danger alert-styled-left alert-dismissible">
                        <span class="font-weight-semibold">Error!</span> <%- messages.error %>
                    </div>
                <% } %>

                <% if (messages.success) { %>
                    <div style="margin: 0 20px 0 20px" class="alert alert-success alert-styled-left alert-arrow-left alert-dismissible">
                        <span class="font-weight-semibold">Success!</span> <%- messages.success %>
                    </div>
                <% } %>

                <div class="card-body">
                    <form action="/forgot-password-smtp-settings" method="post" name="forgotPasswordSmtpForm">
                        <div class="helper-box">
                            <div class="font-weight-semibold mb-2">Easy setup guide</div>
                            <div class="text-muted">
                                This SMTP is only for forgot-password emails.<br>
                                Common setup example: host <code>mail.privateemail.com</code>, port <code>465</code>, secure <code>Yes</code>.
                            </div>
                            <div class="helper-actions">
                                <button type="button" class="helper-chip js-forgot-smtp-fill" data-host="mail.privateemail.com" data-port="465" data-secure="1">Use Common SMTP</button>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>System Status</label>
                                    <select name="status" class="form-control select-fixed-single" data-fouc>
                                        <% if (String(status) === '1'){%>
                                            <option value="1" selected>Active</option>
                                            <option value="0">Inactive</option>
                                        <%}else{%>
                                            <option value="1">Active</option>
                                            <option value="0" selected>Inactive</option>
                                        <%}%>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>Secure</label>
                                    <select id="forgot-smtp-secure" name="smtp_secure" class="form-control select-fixed-single" data-fouc>
                                        <% if (String(smtp_secure) === '1'){%>
                                            <option value="1" selected>Yes</option>
                                            <option value="0">No</option>
                                        <%}else{%>
                                            <option value="1">Yes</option>
                                            <option value="0" selected>No</option>
                                        <%}%>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>SMTP Port</label>
                                    <input type="number" min="1" max="65535" id="forgot-smtp-port" name="smtp_port" value="<%= smtp_port %>" class="form-control" placeholder="465" required>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>SMTP Host</label>
                                    <input type="text" id="forgot-smtp-host" name="smtp_host" value="<%= smtp_host %>" class="form-control" placeholder="mail.privateemail.com" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>SMTP User</label>
                                    <input type="text" name="smtp_user" value="<%= smtp_user %>" class="form-control" placeholder="no-reply@example.com" required>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>SMTP Password</label>
                            <input type="text" name="smtp_pass" value="<%= smtp_pass %>" class="form-control" placeholder="SMTP Password" required>
                        </div>

                        <h6 class="font-weight-semibold">Email Sender</h6>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>From Name</label>
                                    <input type="text" name="from_name" value="<%= from_name %>" class="form-control" required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>From Email</label>
                                    <input type="email" name="from_email" value="<%= from_email %>" class="form-control" required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>Reply-To Email</label>
                                    <input type="email" name="reply_to_email" value="<%= reply_to_email %>" class="form-control" required>
                                </div>
                            </div>
                        </div>

                        <h6 class="font-weight-semibold">Forgot Password Template</h6>
                        <div class="form-group">
                            <label>Email Subject</label>
                            <input type="text" name="email_subject" value="<%= email_subject %>" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label>Email Body</label>
                            <textarea name="email_body" rows="8" class="form-control" required><%= email_body %></textarea>
                            <span class="form-text text-muted">
                                Available placeholders:
                                <code>{{member_name}}</code>,
                                <code>{{member_email}}</code>,
                                <code>{{reset_url}}</code>
                            </span>
                        </div>

                        <div class="text-right">
                            <button type="submit" class="btn btn-primary">Update
                                <i class="icon-paperplane ml-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var smtpHost = document.getElementById("forgot-smtp-host");
        var smtpPort = document.getElementById("forgot-smtp-port");
        var smtpSecure = document.getElementById("forgot-smtp-secure");

        document.querySelectorAll(".js-forgot-smtp-fill").forEach(function (button) {
            button.addEventListener("click", function () {
                if (smtpHost) smtpHost.value = button.getAttribute("data-host") || "";
                if (smtpPort) smtpPort.value = button.getAttribute("data-port") || "";
                if (smtpSecure) smtpSecure.value = button.getAttribute("data-secure") || "1";
                if (window.jQuery && window.jQuery.fn.select2) {
                    window.jQuery(smtpSecure).trigger("change");
                }
            });
        });
    });
</script>
