<!-- Page header -->
<div class="page-header page-header-light">
    <div class="breadcrumb-line breadcrumb-line-light header-elements-md-inline">
        <div class="d-flex">
            <div class="breadcrumb">
                <a href="/" class="breadcrumb-item"><i class="icon-home2 mr-2"></i> Home</a>
                <span class="breadcrumb-item active">Executive Committee Members</span>
            </div>
            <a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
        </div>
    </div>
</div>
<!-- /page header -->

<!-- Content area -->
<div class="content">
    <div class="card">
        <div class="card-header header-elements-inline">
            <h5 class="card-title">Executive Committee Members</h5>
        </div>

        <div class="card-body">
            <% if (messages.error) { %>
                <div class="alert alert-danger alert-styled-left alert-dismissible mb-3">
                    <span class="font-weight-semibold">Error!</span> <%- messages.error %>
                </div>
            <% } %>

            <% if (messages.success) { %>
                <div class="alert alert-success alert-styled-left alert-arrow-left alert-dismissible mb-3">
                    <span class="font-weight-semibold">Success!</span> <%- messages.success %>
                </div>
            <% } %>

            <form action="/executive_committee/settings" method="post" class="mb-3">
                <div class="form-group">
                    <label>Executive Committee Title:</label>
                    <input
                        type="text"
                        name="committee_title"
                        class="form-control"
                        value="<%= committee_title || '' %>"
                        placeholder="FAA Executive Committee 2025-27"
                        required
                    />
                </div>
                <button type="submit" class="btn btn-outline-primary mr-2">
                    <i class="icon-checkmark3 mr-2"></i>
                    Save Title
                </button>
            </form>

            <button onclick="location.href='/executive_committee/add'" type="button" class="btn btn-primary">
                <i class="icon-plus2 mr-2"></i>
                Add Committee Member
            </button>
        </div>

        <table id="list" class="table datatable-basic table-bordered table-striped table-hover">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Designation</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Order</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
<!-- /content area -->

<script>
    $(document).ready(function() {
        function dataLoad() {
            $('#list').DataTable({
                "processing": true,
                "serverSide": true,
                "ordering": false,
                "search": true,
                "destroy": true,
                "pageLength": 50,
                "searching": true,
                "ajax": {
                    "url": "/executive_committee/data_list",
                    "type": "POST",
                    "datatype": "json",
                },
                "createdRow": function(row, data, dataIndex) {
                    if (Number(data.status) === 1) {
                        $('td:eq(6)', row).html('<span class="badge badge-success">Active</span>');
                    } else {
                        $('td:eq(6)', row).html('<span class="badge badge-secondary">Inactive</span>');
                    }
                },
                "columns": [
                    {
                        "data": "image",
                        "render": function(data, type, row) {
                            const img = data
                                ? `/executive_committee_images/${data}`
                                : "https://via.placeholder.com/60x60?text=No+Image";
                            return `<img src="${img}" alt="Member" style="width:60px;height:60px;object-fit:cover;border-radius:6px;border:1px solid #ddd;" />`;
                        }
                    },
                    { "data": "name" },
                    { "data": "designation" },
                    { "data": "email" },
                    { "data": "phone" },
                    { "data": "display_order" },
                    { "data": "status" },
                    { "data": "action" },
                ]
            });
        }

        dataLoad();

        $("#list").on('click', '#delete', function() {
            var delid = $(this).attr('data-delete-id');
            bootbox.confirm({
                title: 'Delete',
                message: 'Do you want to delete this committee member?',
                buttons: {
                    confirm: { label: 'Yes', className: 'btn-primary' },
                    cancel: { label: 'No', className: 'btn-link' }
                },
                callback: function(result) {
                    if (result) {
                        $.ajax({
                            type: "post",
                            url: "/executive_committee/del",
                            data: { del_id: delid },
                            datatype: "json",
                            traditional: true,
                            success: function(data) {
                                if (data.success) {
                                    window.location.href = "/executive_committee";
                                } else {
                                    bootbox.alert({
                                        title: 'Delete Failed!',
                                        message: data.message || "Failed to delete."
                                    });
                                }
                            }
                        });
                    }
                }
            });
        });
    });
</script>
